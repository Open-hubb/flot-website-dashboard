generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  businessName    String
  type            MerchantType @default(QR_ONLY)
  flotMerchantId  String    @unique
  webhookUsername  String    @default("")
  webhookPassword  String    @default("")
  sanityStudioUrl  String?
  inviteToken     String?   @unique
  inviteExpiry    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders              Order[]
  customerOrders      CustomerOrder[]
  notifications       InAppNotification[]
  notifPrefs          NotificationPrefs?
  analyticsEvents     WebsiteAnalyticsEvent[]
  cmsPages            CmsPage[]
  cmsMedia            CmsMedia[]
}

// Populated by incoming Flot webhooks.
// Flot sends each webhook ONCE — stored immediately on receipt.
model Order {
  id            String      @id @default(cuid())
  merchantId    String
  merchant      Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  orderId       String      @unique
  flotRequestId String      @unique
  status        OrderStatus @default(PENDING)
  paymentType   String?
  amount        Decimal?    @db.Decimal(18, 2)
  currency      String?
  rawPayload    Json
  receivedAt    DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([merchantId])
  @@index([status])
  @@index([receivedAt])
}

model NotificationPrefs {
  id            String   @id @default(cuid())
  merchantId    String   @unique
  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  emailDigest   Boolean  @default(true)
  digestFreq    String   @default("DAILY")
  newOrderAlert Boolean  @default(true)
}

model InAppNotification {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([merchantId, read])
}

// Lightweight page view tracker — merchant websites POST to /api/public/track
model WebsiteAnalyticsEvent {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  page       String
  referrer   String?
  createdAt  DateTime @default(now())

  @@index([merchantId, createdAt])
}

// Submitted by merchant websites before the customer pays via Flot.
// Auto-linked to an Order when the Flot webhook arrives.
model CustomerOrder {
  id            String              @id @default(cuid())
  merchantId    String
  merchant      Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  address       String
  city          String
  items         Json
  total         Decimal             @db.Decimal(18, 2)
  currency      String              @default("NLE")
  flotRequestId String?             @unique
  status        CustomerOrderStatus @default(PENDING)
  createdAt     DateTime            @default(now())

  @@index([merchantId, createdAt])
  @@index([status])
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
}

enum CustomerOrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum MerchantType {
  QR_ONLY
  WEBSITE
}

model CmsPage {
  id               String        @id @default(cuid())
  merchantId       String
  merchant         Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  slug             String
  title            String
  draftContent     Json
  publishedContent Json?
  status           CmsPageStatus @default(DRAFT)
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?

  @@unique([merchantId, slug])
  @@index([merchantId])
}

model CmsMedia {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  url        String
  filename   String
  type       String
  size       Int
  createdAt  DateTime @default(now())

  @@index([merchantId])
}

enum CmsPageStatus {
  DRAFT
  PUBLISHED
}
