# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# next-auth v5
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Admin panel + cron auth
ADMIN_SECRET="generate-with: openssl rand -base64 32"
CRON_SECRET="generate-with: openssl rand -base64 32"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@flotme.ai"

# Vercel Blob (CMS media uploads) — create a PUBLIC store in the
# Vercel dashboard (Storage > Create > Blob > Access: Public), connect
# it to the project, and check "Add a read-write token env var".
BLOB_STORE_ID="store_xxxxxxxxxxxxxxxx"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"

# Flot (set to "production" on live, anything else uses staging)
NODE_ENV="development"
