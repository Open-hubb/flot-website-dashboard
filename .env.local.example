# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# next-auth v5
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@flotme.ai"

# Uploadthing (file uploads)
UPLOADTHING_SECRET="sk_live_xxxxxxxxxxxxxxxxxx"
UPLOADTHING_APP_ID="xxxxxxxxxx"

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID="xxxxxxxxxx"
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN="skxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Flot (set to "production" on live, anything else uses staging)
NODE_ENV="development"
